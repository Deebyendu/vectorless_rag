      "source": [
        "def find_nodes_by_ids(tree: list, target_ids: list) -> list:\n",
        "    \"\"\"Recursively search tree for node with matching ID.\"\"\"\n",
        "    found=[]\n",
        "    for node in tree:\n",
        "        if node[\"node_id\"] in target_ids:\n",
        "            found.append(node)\n",
        "        if node.get(\"nodes\"):\n",
        "            found.extend(find_nodes_by_ids(node[\"nodes\"], target_ids))\n",
        "    return found"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": 96,
      "id": "bddc7829",
      "metadata": {},
      "outputs": [],
      "source": [
        "## Generate answer from retrieved nodes\n",
        "def generate_answer(query: str, nodes: list, model: str =\"llama-3.3-70b-versatile\") -> str:\n",
        "    \"\"\"\n",
        "    Takes retrieved nodes as context and generates a grounded answer.\n",
        "    Instructs the LLM to cite section titles and page numbers.\n",
        "    \"\"\"\n",
        "    if not nodes:\n",
        "        return \"No relevant sections found in the document.\"\n",
        "\n",
        "    # Build context string from retrieved nodes\n",
        "    context_parts=[]\n",
        "    for node in nodes:\n",
        "        context_parts.append(\n",
        "            f\"[Section: '{node['title']}' | Page: {node.get('page_index', '?')}]\\n\"\n",
        "            f\"{node.get('text','content not available')}\"\n",
        "        )\n",
        "    context=\"\\n\\n---\\n\\n\".join(context_parts)\n",
        "    \n",
        "    prompt=f\"\"\" you are an expert document analyst.\n",
        "    Answer the question using ONLY the provided context.\n",
        "    for every claim you mnake, cite the section title and page number in parenthese.\n",
        "    Be concise and precise.\n",
        "    \n",
        "    Question: {query}\n",
        "    Context:\n",
        "    {context}\n",
        "    \n",
        "    Answer:\n",
        "    \"\"\"\n",
        "    \n",
        "    response= groq.chat.completions.create(\n",
        "        model=model,\n",
        "        messages=[{\"role\": \"user\", \"content\": prompt}]\n",
        "    )\n",
        "    return response.choices[0].message.content.strip()"
      ]
    },
